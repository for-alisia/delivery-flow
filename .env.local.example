# Copy this file to `.env.local` and replace the token value locally.
# `.env.local` is gitignored and should never be committed.

SONAR_HOST_URL=https://sonarcloud.io
SONAR_ORGANIZATION=for-alisia
SONAR_TOKEN=<replace-with-your-sonar-token>

# SonarCloud project for this repository:
# SONAR_PROJECT_KEY=com.gitlabflow:flow-orchestrator

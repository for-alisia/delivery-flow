{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gitlabflow.local/flow-log/plan-v3.schema.json",
  "title": "Flow-Log Plan Schema v3",
  "description": "Canonical implementation plan schema for flow-log draft workflow. The canonical artifact is artifacts/implementation-plans/<feature>.plan.json and is tool-owned.",
  "type": "object",
  "required": [
    "schemaVersion",
    "feature",
    "revision",
    "status",
    "scope",
    "validationRules",
    "designDecisions",
    "models",
    "classes",
    "slices",
    "verification"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "enum": ["3.0"],
      "description": "Plan schema version.",
      "examples": ["3.0"]
    },
    "feature": {
      "type": "string",
      "minLength": 1,
      "description": "Feature identifier matching the canonical file name.",
      "examples": ["search-enhancement-api"]
    },
    "revision": {
      "type": "integer",
      "minimum": 1,
      "description": "Tool-managed canonical revision. Incremented on accepted content change.",
      "examples": [1]
    },
    "status": {
      "type": "string",
      "description": "Plan lifecycle status.",
      "examples": ["draft"]
    },
    "scope": {
      "type": "object",
      "required": ["purpose", "inScope", "outOfScope", "constraints"],
      "properties": {
        "purpose": {
          "type": "string",
          "description": "Concise objective of the feature plan."
        },
        "inScope": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Items explicitly in scope for this plan revision."
        },
        "outOfScope": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Items intentionally excluded from this plan revision."
        },
        "constraints": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Hard constraints such as constitution, platform, or API limitations."
        }
      },
      "additionalProperties": true
    },
    "implementationFlow": {
      "type": "array",
      "description": "Ordered implementation path that ties constitution and slice ownership to concrete flow steps.",
      "items": {
        "type": "object",
        "required": [
          "id",
          "order",
          "slice",
          "layer",
          "component",
          "responsibility",
          "constitutionReason",
          "outputs"
        ],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "order": { "type": "integer", "minimum": 1 },
          "slice": { "type": "string", "minLength": 1 },
          "layer": { "type": "string", "minLength": 1 },
          "component": { "type": "string", "minLength": 1 },
          "responsibility": { "type": "string", "minLength": 1 },
          "constitutionReason": { "type": "string", "minLength": 1 },
          "outputs": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        },
        "additionalProperties": true
      }
    },
    "contractExamples": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "label", "type", "body"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "label": { "type": "string", "minLength": 1 },
          "type": {
            "type": "string",
            "enum": ["request", "success", "error", "validation-error"]
          },
          "body": {
            "description": "Representative payload fragment. Any JSON value is allowed.",
            "type": ["object", "array", "string", "number", "integer", "boolean", "null"]
          }
        },
        "additionalProperties": true
      }
    },
    "validationRules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "rule", "owner", "reason", "appliesToSlices"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "rule": { "type": "string", "minLength": 1 },
          "owner": { "type": "string", "minLength": 1 },
          "reason": { "type": "string", "minLength": 1 },
          "appliesToSlices": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        },
        "additionalProperties": true
      }
    },
    "designDecisions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "decision", "rationale", "alternatives"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "decision": { "type": "string", "minLength": 1 },
          "rationale": { "type": "string", "minLength": 1 },
          "alternatives": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        },
        "additionalProperties": true
      }
    },
    "models": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "qualifiedName",
          "kind",
          "status",
          "purpose",
          "placementJustification",
          "ownedBySlices"
        ],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "qualifiedName": { "type": "string", "minLength": 1 },
          "kind": {
            "type": "string",
            "enum": ["record", "enum", "interface", "sealed-interface", "class"]
          },
          "status": {
            "type": "string",
            "enum": ["new", "modified", "existing"]
          },
          "purpose": { "type": "string", "minLength": 1 },
          "placementJustification": { "type": "string", "minLength": 1 },
          "ownedBySlices": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        },
        "additionalProperties": true
      }
    },
    "classes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "path", "status", "role", "ownedBySlices"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "path": { "type": "string", "minLength": 1 },
          "status": {
            "type": "string",
            "enum": ["new", "modified", "existing"]
          },
          "role": { "type": "string", "minLength": 1 },
          "ownedBySlices": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        },
        "additionalProperties": true
      }
    },
    "slices": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "goal",
          "dependsOn",
          "flowSteps",
          "covers",
          "implementationTasks",
          "tests",
          "logging",
          "doneWhen"
        ],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "goal": { "type": "string", "minLength": 1 },
          "dependsOn": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "flowSteps": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "covers": {
            "type": "object",
            "required": ["models", "classes", "validationRules", "examples", "decisions"],
            "properties": {
              "models": { "type": "array", "items": { "type": "string", "minLength": 1 } },
              "classes": { "type": "array", "items": { "type": "string", "minLength": 1 } },
              "validationRules": { "type": "array", "items": { "type": "string", "minLength": 1 } },
              "examples": { "type": "array", "items": { "type": "string", "minLength": 1 } },
              "decisions": { "type": "array", "items": { "type": "string", "minLength": 1 } }
            },
            "additionalProperties": true
          },
          "implementationTasks": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "tests": {
            "type": "object",
            "required": ["unit", "integration", "component"],
            "properties": {
              "unit": { "type": "array", "items": { "type": "string", "minLength": 1 } },
              "integration": { "type": "array", "items": { "type": "string", "minLength": 1 } },
              "component": { "type": "array", "items": { "type": "string", "minLength": 1 } }
            },
            "additionalProperties": true
          },
          "logging": {
            "type": "object",
            "required": ["info", "warn", "error"],
            "properties": {
              "info": { "type": "array", "items": { "type": "string", "minLength": 1 } },
              "warn": { "type": "array", "items": { "type": "string", "minLength": 1 } },
              "error": { "type": "array", "items": { "type": "string", "minLength": 1 } }
            },
            "additionalProperties": true
          },
          "doneWhen": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "flags": {
            "type": "object",
            "properties": {
              "contractChanges": { "type": "boolean" },
              "validationSensitive": { "type": "boolean" }
            },
            "additionalProperties": true
          }
        },
        "additionalProperties": true
      }
    },
    "verification": {
      "type": "object",
      "required": ["slices", "finalGates"],
      "properties": {
        "slices": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["slice", "checks", "evidence"],
            "properties": {
              "slice": { "type": "string", "minLength": 1 },
              "checks": { "type": "array", "items": { "type": "string", "minLength": 1 } },
              "evidence": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": true
          }
        },
        "finalGates": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["gate", "owner", "required", "evidence"],
            "properties": {
              "gate": { "type": "string", "minLength": 1 },
              "owner": { "type": "string", "minLength": 1 },
              "required": { "type": "boolean" },
              "evidence": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "hash": {
      "type": ["string", "null"],
      "description": "Tool-managed deterministic SHA-256 hash of canonical plan content.",
      "examples": ["6db57f6e7864cc87f6adfcb75de96f5f2e5e04f81eb9e531f5765f5d2da25837"]
    }
  },
  "additionalProperties": true,
  "examples": [
    {
      "schemaVersion": "3.0",
      "feature": "example-feature",
      "revision": 1,
      "status": "draft",
      "scope": {
        "purpose": "Add audit metadata to search responses",
        "inScope": ["search endpoint", "dto mapping"],
        "outOfScope": ["new endpoint"],
        "constraints": ["reuse existing error contract"]
      },
      "implementationFlow": [
        {
          "id": "F1",
          "order": 1,
          "slice": "S1",
          "layer": "orchestration",
          "component": "IssuesService",
          "responsibility": "Run base search and branch for audit enrichment",
          "constitutionReason": "Protect orchestration boundary",
          "outputs": ["issue page"]
        }
      ],
      "contractExamples": [
        {
          "id": "EX1",
          "label": "audit request",
          "type": "request",
          "body": {
            "filters": {
              "audit": ["label"]
            }
          }
        }
      ],
      "validationRules": [
        {
          "id": "VR1",
          "rule": "audit values must be supported",
          "owner": "IssuesRequestMapper",
          "reason": "shared mapper validation",
          "appliesToSlices": ["S1"]
        }
      ],
      "designDecisions": [
        {
          "id": "D1",
          "title": "Use dependent-then-parallel composition",
          "decision": "Search first, then enrich in parallel",
          "rationale": "Issue IDs required for enrichment",
          "alternatives": ["parallel-first"]
        }
      ],
      "models": [
        {
          "id": "M1",
          "qualifiedName": "com.example.SearchInput",
          "kind": "record",
          "status": "new",
          "purpose": "carry query + audit types",
          "placementJustification": "orchestration use-case input",
          "ownedBySlices": ["S1"]
        }
      ],
      "classes": [
        {
          "id": "C1",
          "path": "src/main/java/com/example/IssuesService.java",
          "status": "modified",
          "role": "search + enrichment orchestration",
          "ownedBySlices": ["S1"]
        }
      ],
      "slices": [
        {
          "id": "S1",
          "title": "Orchestration implementation",
          "goal": "enable audit enrichment path",
          "dependsOn": [],
          "flowSteps": ["F1"],
          "covers": {
            "models": ["M1"],
            "classes": ["C1"],
            "validationRules": ["VR1"],
            "examples": ["EX1"],
            "decisions": ["D1"]
          },
          "implementationTasks": ["update service", "add mapper branch"],
          "tests": {
            "unit": ["IssuesServiceTest"],
            "integration": [],
            "component": []
          },
          "logging": {
            "info": ["log enrichment branch"],
            "warn": [],
            "error": []
          },
          "doneWhen": ["all tests pass"],
          "flags": {
            "contractChanges": true,
            "validationSensitive": true
          }
        }
      ],
      "verification": {
        "slices": [
          {
            "slice": "S1",
            "checks": ["unit", "integration"],
            "evidence": "IssuesServiceTest and IssuesControllerIT"
          }
        ],
        "finalGates": [
          {
            "gate": "finalCheck",
            "owner": "TL",
            "required": true,
            "evidence": "scripts/final-check.sh"
          }
        ]
      },
      "hash": null
    }
  ]
}

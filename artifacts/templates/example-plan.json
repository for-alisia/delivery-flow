  "status": "draft",

  "payloadExamples": [
    {
      "label": "Search with label audit",
      "type": "request",
      "body": {
        "pagination": { "page": 1, "perPage": 20 },
        "filters": { "state": "opened", "audit": ["label"] }
      }
    },
    {
      "label": "Success response with audit",
      "type": "success",
      "body": {
        "items": [
          {
            "id": 101,
            "issueId": 17,
            "title": "Deploy failure",
            "changeSets": [
              {
                "changeType": "add",
                "changedBy": { "id": 1, "username": "root", "name": "Administrator" },
                "change": { "field": "label", "id": 73, "name": "bug" },
                "changedAt": "2026-01-15T09:30:00Z"
              }
            ]
          }
        ],
        "count": 1,
        "page": 1
      }
    },
    {
      "label": "Success response without audit",
      "type": "success",
      "body": {
        "items": [
          {
            "id": 101,
            "issueId": 17,
            "title": "Deploy failure",
            "state": "opened"
          }
        ],
        "count": 1,
        "page": 1
      }
    },
    {
      "label": "Enrichment failure",
      "type": "error",
      "body": {
        "code": "INTEGRATION_FAILURE",
        "message": "GitLab get label events operation failed",
        "details": []
      }
    },
    {
      "label": "Unsupported audit value",
      "type": "validation-error",
      "body": {
        "code": "VALIDATION_ERROR",
        "message": "Request validation failed",
        "details": ["filters.audit must contain only supported values [label]"]
      }
    }
  ],

  "validationBoundary": [
    {
      "rule": "pagination.page and pagination.perPage must be positive",
      "boundary": "REST DTO binding (PaginationRequest)",
      "reason": "Standard scalar validation belongs at HTTP binding"
    },
    {
      "rule": "audit may contain only supported values",
      "boundary": "IssuesRequestMapper when building SearchIssuesInput",
      "reason": "Supported audit types are orchestration semantics that must still ignore null entries"
    },
    {
      "rule": "perPage <= 40",
      "boundary": "IssuesService.validatePerPage using IssuesApiProperties.maxPageSize()",
      "reason": "Existing runtime guard remains the single owner of configurable page-size enforcement"
    }
  ],

  "models": [
    {
      "qualifiedName": "com.gitlabflow.floworchestrator.orchestration.issues.model.Issue",
      "type": "record",
      "status": "modified",
      "fields": [
        { "name": "id", "type": "long", "nullable": false },
        { "name": "issueId", "type": "long", "nullable": false },
        { "name": "title", "type": "String", "nullable": false },
        { "name": "description", "type": "String", "nullable": true },
        { "name": "state", "type": "String", "nullable": false },
        { "name": "labels", "type": "List<String>", "nullable": false, "defensiveCopy": true },
        { "name": "assignee", "type": "String", "nullable": true },
        { "name": "milestone", "type": "String", "nullable": true },
        { "name": "parent", "type": "Long", "nullable": true },
        { "name": "changeSets", "type": "List<ChangeSet>", "nullable": true, "defensiveCopy": true }
      ],
      "annotations": ["@Builder"],
      "justification": "Issue is the orchestration-layer entity per constitution Principle 2 (domain models live in orchestration). changeSets is nullable (not empty list) because null means audit was not requested — distinct from empty list meaning no events found. This follows constitution Principle 4 (explicit null semantics). Defensive copy on labels and changeSets per code-guidance immutability rule.",
      "notes": "Preserve changeSets=null when audit not requested, else List.copyOf(changeSets)"
    },
    {
      "qualifiedName": "com.gitlabflow.floworchestrator.orchestration.issues.model.SearchIssuesInput",
      "type": "record",
      "status": "new",
      "fields": [
        { "name": "query", "type": "IssueQuery", "nullable": false },
        { "name": "auditTypes", "type": "List<IssueAuditType>", "nullable": false, "defensiveCopy": true }
      ],
      "annotations": ["@Builder"],
      "justification": "SearchIssuesInput wraps IssueQuery + audit types as a single orchestration input. Kept separate from IssueQuery because audit processing is orchestration-layer concern (enrichment logic), while IssueQuery maps 1:1 to the adapter call. auditTypes is non-null with empty-list default because null vs empty has no semantic difference here — absence of audit is an empty list.",
      "notes": "Normalize null auditTypes to List.of()"
    },
    {
      "qualifiedName": "com.gitlabflow.floworchestrator.orchestration.issues.model.IssueAuditType",
      "type": "enum",
      "status": "new",
      "values": ["LABEL"],
      "methods": ["String value()", "@Nullable static IssueAuditType fromValue(String raw)"],
      "justification": "Enum in orchestration layer because audit types are domain concepts that drive orchestration behavior (which enrichment calls to make). fromValue returns null for unknown strings so the mapper can collect unsupported values and report a clean validation error.",
      "notes": "Future values append here without changing the port contract"
    }
  ],

  "classes": [
    {
      "path": "flow-orchestrator/src/main/java/com/gitlabflow/floworchestrator/orchestration/issues/IssuesService.java",
      "status": "modified",

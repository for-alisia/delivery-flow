    },
    {
      "path": "flow-orchestrator/src/main/java/com/gitlabflow/floworchestrator/integration/gitlab/issues/mapper/GitLabIssuesMapper.java",
      "status": "modified",
      "role": "Build base Issue objects with changeSets=null"
    },
    {
      "path": "flow-orchestrator/src/main/java/com/gitlabflow/floworchestrator/config/IssuesApiProperties.java",
      "status": "modified",
      "role": "Tighten config max to 40"
    },
    {
      "path": "flow-orchestrator/src/main/resources/application.yml",
      "status": "modified",
      "role": "Set default-page-size=20 and max-page-size=40"
    },
    {
      "path": "flow-orchestrator/http/issues.http",
      "status": "modified",
      "role": "Add audit-enabled search and validation error examples"
    },
    {
      "path": "documentation/capabilities/issues.md",
      "status": "modified",
      "role": "Document SearchIssuesInput, IssueDto.changeSets, audit transport subtypes, fail-fast merge"
    }
  ],

  "compositionStrategy": {
    "approach": "dependent-then-parallel",
    "description": "Search runs first (needs issueIds), then parallel label-event enrichment per issue via AsyncComposer.submit + joinFailFast"
  },

